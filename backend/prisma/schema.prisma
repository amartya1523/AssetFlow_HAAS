// =============================================================================
// AssetFlow - Prisma Schema
// Enterprise Asset & Resource Management System
// Database: PostgreSQL
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL is configured in prisma.config.ts (Prisma ORM v7)
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum UserRole {
  EMPLOYEE
  DEPARTMENT_HEAD
  ASSET_MANAGER
  ADMIN
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditCycleStatus {
  OPEN
  CLOSED
}

enum AuditResult {
  VERIFIED
  MISSING
  DAMAGED
}

enum NotificationCategory {
  ALERT
  APPROVAL
  BOOKING
  GENERAL
}

// -----------------------------------------------------------------------------
// User & Organization
// -----------------------------------------------------------------------------

model User {
  id                     String       @id @default(uuid())
  name                   String
  email                  String       @unique
  passwordHash           String
  phone                  String?
  avatarUrl              String?
  role                   UserRole     @default(EMPLOYEE)
  status                 RecordStatus @default(ACTIVE)
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  departmentId           String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  department           Department?           @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  headedDepartment     Department[]          @relation("DepartmentHead")
  allocations          Allocation[]          @relation("AllocationToUser")
  transfersFrom        Transfer[]            @relation("TransferFromUser")
  transfersTo          Transfer[]            @relation("TransferToUser")
  transfersRequested   Transfer[]            @relation("TransferRequestedBy")
  bookings             Booking[]             @relation("BookingByUser")
  maintenanceRaised    MaintenanceRequest[]  @relation("MaintenanceRaisedBy")
  maintenanceApproved  MaintenanceRequest[]  @relation("MaintenanceApprovedBy")
  createdAuditCycles   AuditCycle[]          @relation("AuditCycleCreatedBy")
  auditAssignments     AuditCycleAuditor[]   @relation("AuditCycleAuditorUser")
  notifications        Notification[]
  activityLogs         ActivityLog[]

  @@index([role])
  @@index([status])
  @@index([departmentId])
  @@index([createdAt])
  @@map("users")
}

model Department {
  id                 String       @id @default(uuid())
  name               String
  code               String       @unique
  headId             String?
  parentDepartmentId String?
  status             RecordStatus @default(ACTIVE)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  head               User?         @relation("DepartmentHead", fields: [headId], references: [id], onDelete: SetNull)
  parentDepartment   Department?   @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  childDepartments   Department[]  @relation("DepartmentHierarchy")
  members            User[]        @relation("DepartmentMembers")
  assets             Asset[]
  allocations        Allocation[]  @relation("AllocationToDepartment")
  scopedAuditCycles  AuditCycle[]  @relation("AuditCycleDepartment")

  @@unique([name, code])
  @@index([headId])
  @@index([parentDepartmentId])
  @@index([status])
  @@map("departments")
}

// -----------------------------------------------------------------------------
// Assets
// -----------------------------------------------------------------------------

model AssetCategory {
  id               String       @id @default(uuid())
  name             String       @unique
  extraFieldsSchema Json?
  status           RecordStatus @default(ACTIVE)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  assets Asset[]

  @@index([status])
  @@map("asset_categories")
}

model Asset {
  id              String      @id @default(uuid())
  name            String
  categoryId      String
  departmentId    String?
  assetTag        String      @unique
  serialNumber    String?
  acquisitionDate DateTime?
  acquisitionCost Decimal?    @db.Decimal(12, 2)
  condition       String?
  location        String?
  photoUrl        String?
  isBookable      Boolean     @default(false)
  status          AssetStatus @default(AVAILABLE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  category            AssetCategory        @relation(fields: [categoryId], references: [id])
  department          Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  allocations         Allocation[]
  transfers           Transfer[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]

  @@index([assetTag])
  @@index([serialNumber])
  @@index([status])
  @@index([categoryId])
  @@index([departmentId])
  @@index([location])
  @@index([createdAt])
  @@map("assets")
}

// -----------------------------------------------------------------------------
// Allocation & Transfer
// -----------------------------------------------------------------------------

model Allocation {
  id                      String           @id @default(uuid())
  assetId                 String
  allocatedToUserId       String?
  allocatedToDepartmentId String?
  allocatedAt             DateTime         @default(now())
  expectedReturnDate      DateTime?
  actualReturnDate        DateTime?
  conditionNoteOnReturn   String?
  status                  AllocationStatus @default(ACTIVE)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  asset                 Asset       @relation(fields: [assetId], references: [id])
  allocatedToUser       User?       @relation("AllocationToUser", fields: [allocatedToUserId], references: [id], onDelete: SetNull)
  allocatedToDepartment Department? @relation("AllocationToDepartment", fields: [allocatedToDepartmentId], references: [id], onDelete: SetNull)

  @@index([assetId])
  @@index([allocatedToUserId])
  @@index([allocatedToDepartmentId])
  @@index([status])
  @@index([expectedReturnDate])
  @@index([createdAt])
  @@map("allocations")
}

model Transfer {
  id            String         @id @default(uuid())
  assetId        String
  fromUserId     String?
  toUserId       String?
  requestedById  String
  reason         String
  status         TransferStatus @default(REQUESTED)
  requestedAt    DateTime       @default(now())
  resolvedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  asset         Asset  @relation(fields: [assetId], references: [id])
  fromUser      User?  @relation("TransferFromUser", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUser        User?  @relation("TransferToUser", fields: [toUserId], references: [id], onDelete: SetNull)
  requestedBy   User   @relation("TransferRequestedBy", fields: [requestedById], references: [id])

  @@index([assetId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([requestedById])
  @@index([status])
  @@index([requestedAt])
  @@map("transfers")
}

// -----------------------------------------------------------------------------
// Resource Booking
// -----------------------------------------------------------------------------

model Booking {
  id         String        @id @default(uuid())
  assetId     String
  bookedById  String
  startTime   DateTime
  endTime     DateTime
  status      BookingStatus @default(UPCOMING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  asset     Asset @relation(fields: [assetId], references: [id])
  bookedBy  User  @relation("BookingByUser", fields: [bookedById], references: [id])

  @@index([assetId])
  @@index([bookedById])
  @@index([status])
  @@index([startTime])
  @@index([endTime])
  @@index([createdAt])
  @@map("bookings")
}

// -----------------------------------------------------------------------------
// Maintenance
// -----------------------------------------------------------------------------

model MaintenanceRequest {
  id              String              @id @default(uuid())
  assetId          String
  raisedById       String
  issueDescription String
  priority         MaintenancePriority @default(MEDIUM)
  photoUrl         String?
  status           MaintenanceStatus   @default(PENDING)
  technicianName   String?
  rejectionReason  String?
  approvedById     String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  resolvedAt       DateTime?

  asset       Asset  @relation(fields: [assetId], references: [id])
  raisedBy    User   @relation("MaintenanceRaisedBy", fields: [raisedById], references: [id])
  approvedBy  User?  @relation("MaintenanceApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([assetId])
  @@index([raisedById])
  @@index([approvedById])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("maintenance_requests")
}

// -----------------------------------------------------------------------------
// Audit
// -----------------------------------------------------------------------------

model AuditCycle {
  id               String           @id @default(uuid())
  name             String
  scopeDepartmentId String?
  scopeLocation    String?
  startDate        DateTime
  endDate          DateTime
  status           AuditCycleStatus @default(OPEN)
  createdById      String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  scopeDepartment Department?       @relation("AuditCycleDepartment", fields: [scopeDepartmentId], references: [id], onDelete: SetNull)
  createdBy       User              @relation("AuditCycleCreatedBy", fields: [createdById], references: [id])
  auditors        AuditCycleAuditor[]
  items           AuditItem[]

  @@index([scopeDepartmentId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([createdById])
  @@index([createdAt])
  @@map("audit_cycles")
}

model AuditCycleAuditor {
  id          String    @id @default(uuid())
  auditCycleId String
  auditorId    String
  assignedAt   DateTime  @default(now())

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  auditor    User       @relation("AuditCycleAuditorUser", fields: [auditorId], references: [id])

  @@unique([auditCycleId, auditorId])
  @@index([auditorId])
  @@map("audit_cycle_auditors")
}

model AuditItem {
  id               String      @id @default(uuid())
  auditCycleId     String
  assetId          String
  expectedLocation String?
  result           AuditResult?
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  asset      Asset      @relation(fields: [assetId], references: [id])

  @@unique([auditCycleId, assetId])
  @@index([auditCycleId])
  @@index([assetId])
  @@index([result])
  @@map("audit_items")
}

// -----------------------------------------------------------------------------
// Notifications & Activity Log
// -----------------------------------------------------------------------------

model Notification {
  id        String               @id @default(uuid())
  userId    String
  category  NotificationCategory @default(GENERAL)
  type      String
  message   String
  isRead    Boolean              @default(false)
  createdAt DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}
