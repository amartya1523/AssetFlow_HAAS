// =============================================================================
// AssetFlow - Prisma Schema
// Enterprise Asset & Resource Management System
// Database: PostgreSQL
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL is configured in prisma.config.ts (Prisma ORM v7)
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum UserRole {
  EMPLOYEE
  DEPARTMENT_HEAD
  ASSET_MANAGER
  ADMIN
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  REVOKED
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  INSPECTION
  REPAIR
}

enum MaintenanceStatus {
  REQUESTED
  APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AuditCycleStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AuditItemStatus {
  PENDING
  VERIFIED
  MISMATCH
  MISSING
  NOT_FOUND
}

enum NotificationCategory {
  ALERT
  APPROVAL
  BOOKING
  GENERAL
}

// -----------------------------------------------------------------------------
// User & Organization
// -----------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatarUrl    String?
  role         UserRole @default(EMPLOYEE)
  isActive     Boolean  @default(true)
  departmentId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  department          Department?      @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  headOfDepartment    Department?      @relation("DepartmentHead")
  allocations         Allocation[]
  transfersInitiated  Transfer[]       @relation("TransferInitiator")
  transfersReceived   Transfer[]       @relation("TransferReceiver")
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditCycles         AuditCycleAuditor[]
  auditItems          AuditItem[]      @relation("AuditItemAuditor")
  notifications       Notification[]
  activityLogs        ActivityLog[]

  @@index([role])
  @@index([departmentId])
  @@map("users")
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?
  headId      String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  head     User?     @relation("DepartmentHead", fields: [headId], references: [id], onDelete: SetNull)
  members  User[]    @relation("DepartmentMembers")
  assets   Asset[]
  bookings Booking[]

  @@index([headId])
  @@map("departments")
}

// -----------------------------------------------------------------------------
// Assets
// -----------------------------------------------------------------------------

model AssetCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets Asset[]

  @@map("asset_categories")
}

model Asset {
  id          String      @id @default(uuid())
  assetTag    String      @unique
  name        String
  description String?
  status      AssetStatus @default(AVAILABLE)
  serialNumber String?
  model       String?
  brand       String?
  purchaseDate DateTime?
  purchaseValue Decimal?  @db.Decimal(12, 2)
  currentValue  Decimal?  @db.Decimal(12, 2)
  imageUrl    String?
  location    String?
  notes       String?

  categoryId   String         @unique
  departmentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  category          AssetCategory      @relation(fields: [categoryId], references: [id])
  department        Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  allocations       Allocation[]       @relation("AssetAllocationHistory")
  transfers         Transfer[]
  bookings          Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems        AuditItem[]

  @@index([status])
  @@index([categoryId])
  @@index([departmentId])
  @@index([assetTag])
  @@index([createdAt])
  @@map("assets")
}

// -----------------------------------------------------------------------------
// Allocation & Transfer
// -----------------------------------------------------------------------------

model Allocation {
  id         String           @id @default(uuid())
  assetId    String
  userId     String
  status     AllocationStatus @default(ACTIVE)
  notes      String?
  allocatedAt DateTime        @default(now())
  returnedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  asset Asset @relation("AssetAllocationHistory", fields: [assetId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([assetId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("allocations")
}

model Transfer {
  id          String         @id @default(uuid())
  assetId     String
  fromDepartmentId String?
  toDepartmentId   String?
  initiatedById String
  receivedById  String?
  status      TransferStatus @default(PENDING)
  reason      String
  notes       String?
  requestedAt DateTime       @default(now())
  approvedAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  asset       Asset      @relation(fields: [assetId], references: [id])
  initiator   User       @relation("TransferInitiator", fields: [initiatedById], references: [id])
  receiver    User?      @relation("TransferReceiver", fields: [receivedById], references: [id], onDelete: SetNull)

  @@index([assetId])
  @@index([status])
  @@index([initiatedById])
  @@index([toDepartmentId])
  @@index([createdAt])
  @@map("transfers")
}

// -----------------------------------------------------------------------------
// Resource Booking
// -----------------------------------------------------------------------------

model Booking {
  id          String        @id @default(uuid())
  assetId     String
  userId      String
  departmentId String?
  status      BookingStatus @default(PENDING)
  purpose     String
  startTime   DateTime
  endTime     DateTime
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  asset      Asset      @relation(fields: [assetId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([assetId])
  @@index([userId])
  @@index([status])
  @@index([startTime])
  @@index([endTime])
  @@index([departmentId])
  @@index([createdAt])
  @@map("bookings")
}

// -----------------------------------------------------------------------------
// Maintenance
// -----------------------------------------------------------------------------

model MaintenanceRequest {
  id           String           @id @default(uuid())
  assetId      String
  requestedById String
  assignedToId String?
  type         MaintenanceType  @default(CORRECTIVE)
  status       MaintenanceStatus @default(REQUESTED)
  issue        String
  resolution   String?
  cost         Decimal?         @db.Decimal(12, 2)
  requestedAt  DateTime         @default(now())
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  asset       Asset @relation(fields: [assetId], references: [id])
  requestedBy User  @relation(fields: [requestedById], references: [id])

  @@index([assetId])
  @@index([status])
  @@index([type])
  @@index([requestedById])
  @@index([createdAt])
  @@map("maintenance_requests")
}

// -----------------------------------------------------------------------------
// Audit
// -----------------------------------------------------------------------------

model AuditCycle {
  id          String           @id @default(uuid())
  name        String
  description String?
  status      AuditCycleStatus @default(DRAFT)
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  auditors AuditCycleAuditor[]
  items    AuditItem[]

  @@index([status])
  @@index([startDate])
  @@index([createdAt])
  @@map("audit_cycles")
}

model AuditCycleAuditor {
  id          String     @id @default(uuid())
  auditCycleId String
  userId      String
  assignedAt  DateTime   @default(now())

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@unique([auditCycleId, userId])
  @@index([userId])
  @@map("audit_cycle_auditors")
}

model AuditItem {
  id              String         @id @default(uuid())
  auditCycleId    String
  assetId         String
  auditorId       String?
  status          AuditItemStatus @default(PENDING)
  expectedLocation String?
  actualLocation  String?
  remarks         String?
  checkedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  asset      Asset      @relation(fields: [assetId], references: [id])
  auditor    User?      @relation("AuditItemAuditor", fields: [auditorId], references: [id], onDelete: SetNull)

  @@index([auditCycleId])
  @@index([assetId])
  @@index([status])
  @@index([auditorId])
  @@map("audit_items")
}

// -----------------------------------------------------------------------------
// Notifications & Activity Log
// -----------------------------------------------------------------------------

model Notification {
  id         String               @id @default(uuid())
  userId     String
  category   NotificationCategory @default(GENERAL)
  title      String
  message    String
  isRead     Boolean              @default(false)
  linkUrl    String?
  createdAt  DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entityType String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}
